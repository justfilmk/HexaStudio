{
  "name": "hexastudio",
  "version": "0.1.0",
  "private": true,
  "description": "HexaStudio.net — 3D creative studio platform",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "apps/cms",
    "packages/types",
    "packages/utils"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:cms": "npm run develop --workspace=apps/cms",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "test:e2e": "npm run test:e2e --workspace=apps/frontend",
    "test:e2e:ui": "playwright test --ui --config e2e/playwright.config.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "react-redux": "^9.3.0"
  }
}
