# --- Server Configuration ---
SERVER_IP=127.0.0.1

# --- Environment ---
NODE_ENV=development
DOMAIN=hexastudio.net
ACME_EMAIL=admin@hexastudio.net

# --- PostgreSQL ---
POSTGRES_USER=hexastudio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hexastudio

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password

# --- MinIO S3-compatible Storage ---
MINIO_ROOT_USER=hexastudio
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_TEXTURES=textures
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_HDR=hdr
MINIO_BUCKET_BACKUPS=backups

# --- Backend (NestJS) ---
PORT=4000
BACKEND_PORT=4000
JWT_SECRET=change_me_random_string
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,https://hexastudio.net
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
SENTRY_DSN=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_CMS_URL=http://localhost:1337
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=

# --- CMS (Strapi) ---
STRAPI_PORT=1337
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=change_me_random_string
STRAPI_ADMIN_JWT_SECRET=change_me_random_string
STRAPI_TRANSFER_TOKEN_SALT=change_me_random_string
STRAPI_JWT_SECRET=change_me_random_string

# --- Traefik ---
TRAEFIK_DASHBOARD_HOST=traefik.localhost
TRAEFIK_ACME_ENABLED=false

# --- Hostnames ---
FRONTEND_HOST=localhost:3000
API_HOST=localhost:4000
CMS_HOST=localhost:1337
MINIO_API_HOST=localhost:9000
MINIO_CONSOLE_HOST=localhost:9001
GRAFANA_HOST=localhost:3001
PROMETHEUS_HOST=localhost:9090

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_strong_password

# --- Sentry ---
SENTRY_ENVIRONMENT=development
