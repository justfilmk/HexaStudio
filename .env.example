# --- Server Configuration ---
SERVER_IP=156.206.135.186
DOMAIN=hexastudio.net
ACME_EMAIL=admin@hexastudio.net

# --- Environment ---
NODE_ENV=production

# --- PostgreSQL ---
POSTGRES_USER=hexastudio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hexastudio

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password

# --- MinIO S3-compatible Storage ---
MINIO_ROOT_USER=hexastudio
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_TEXTURES=textures
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_HDR=hdr
MINIO_BUCKET_BACKUPS=backups

# --- Backend (NestJS) ---
PORT=4000
BACKEND_PORT=4000
JWT_SECRET=change_me_random_string
JWT_EXPIRES_IN=7d
CORS_ORIGINS=https://hexastudio.net,https://opencode.hexastudio.net
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
SENTRY_DSN=your_sentry_dsn_here

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=https://api.hexastudio.net/api
NEXT_PUBLIC_CMS_URL=https://cms.hexastudio.net
NEXT_PUBLIC_SITE_URL=https://hexastudio.net
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# --- CMS (Strapi) ---
STRAPI_PORT=1337
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=change_me_random_string
STRAPI_ADMIN_JWT_SECRET=change_me_random_string
STRAPI_TRANSFER_TOKEN_SALT=change_me_random_string
STRAPI_JWT_SECRET=change_me_random_string

# --- Traefik ---
TRAEFIK_DASHBOARD_HOST=traefik.hexastudio.net
TRAEFIK_ACME_ENABLED=true

# --- Hostnames ---
FRONTEND_HOST=hexastudio.net
API_HOST=api.hexastudio.net
CMS_HOST=cms.hexastudio.net
MINIO_API_HOST=storage.hexastudio.net
MINIO_CONSOLE_HOST=storage-console.hexastudio.net
GRAFANA_HOST=grafana.hexastudio.net
PROMETHEUS_HOST=prometheus.hexastudio.net

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_strong_password

# --- Sentry ---
SENTRY_ENVIRONMENT=production
