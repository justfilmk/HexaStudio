# =============================================================================
# HexaStudio — Environment Template
# Copy to .env and fill in values. NEVER commit .env with real secrets.
# =============================================================================

# --- General ---
NODE_ENV=production
DOMAIN=hexastudio.net

# --- Traefik ---
TRAEFIK_DASHBOARD_HOST=traefik.hexastudio.net
ACME_EMAIL=admin@hexastudio.net
# In dev (localhost), leave as false. In prod, set to true.
# Uses HTTP-01 challenge (port 80 must be reachable) — works behind Cloudflare proxied DNS.
TRAEFIK_ACME_ENABLED=false

# Cloudflare API credentials (for DNS-01 ACME challenge — uncomment in production):
# CLOUDFLARE_EMAIL=admin@hexastudio.net
# CLOUDFLARE_API_KEY=your_cloudflare_global_api_key

# --- Service Hosts (Traefik routing) ---
FRONTEND_HOST=hexastudio.net
API_HOST=api.hexastudio.net
CMS_HOST=cms.hexastudio.net
MINIO_API_HOST=storage.hexastudio.net
MINIO_CONSOLE_HOST=storage-console.hexastudio.net
GRAFANA_HOST=monitor.hexastudio.net
PROMETHEUS_HOST=prometheus.hexastudio.net

# --- PostgreSQL (internal network only) ---
POSTGRES_USER=hexastudio
POSTGRES_PASSWORD=iP@ssw0rd
POSTGRES_DB=hexastudio

# --- Redis (internal network only) ---
REDIS_PASSWORD=iP@ssw0rd

# --- MinIO ---
MINIO_ROOT_USER=hexastudio
MINIO_ROOT_PASSWORD=iP@ssw0rd
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_TEXTURES=textures
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_HDR=hdr
MINIO_BUCKET_BACKUPS=backups

# --- Backend (NestJS) ---
BACKEND_PORT=4000
JWT_SECRET=iP@ssw0rd4ever@1
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,https://hexastudio.net
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://api.localhost
NEXT_PUBLIC_CMS_URL=http://cms.localhost
NEXT_PUBLIC_SITE_URL=http://localhost

# --- Strapi CMS ---
STRAPI_PORT=1337
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=change_me_api_token_salt
STRAPI_ADMIN_JWT_SECRET=iP@ssw0rd
STRAPI_TRANSFER_TOKEN_SALT=change_me_transfer_token_salt
STRAPI_JWT_SECRET=iP@ssw0rd

# --- Sentry (error tracking) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=iP@ssw0rd
